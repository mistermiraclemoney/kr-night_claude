{
  "expo": {
    "name": "KR NIGHT",
    "slug": "kr-night",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "krnight",
    "backgroundColor": "#0B0B14",
    "splash": {
      "backgroundColor": "#0B0B14"
    },
    "ios": {
      "bundleIdentifier": "app.krnight.mobile",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "매장 QR 체크인 스캔을 위해 카메라를 사용합니다. Camera is used to scan QR check-ins at partner venues."
      }
    },
    "android": {
      "package": "app.krnight.mobile",
      "permissions": ["CAMERA"],
      "adaptiveIcon": {
        "backgroundColor": "#0B0B14"
      }
    },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "매장 QR 체크인 스캔을 위해 카메라를 사용합니다." }
      ]
    ]
  }
}
